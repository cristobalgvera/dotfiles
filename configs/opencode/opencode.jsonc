{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-wakatime"],
  "model": "github-copilot/gpt-5.2-codex",
  "default_agent": "OpenAgent",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
  },
}
