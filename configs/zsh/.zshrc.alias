#!/bin/bash

alias ls='eza --icons --all --group-directories-first --long --header --git --no-user --octal-permissions'
alias lt='ls --tree --level 3'
alias bup='brew cu --yes && brew upgrade && brew cleanup'
alias py='uv run python'
alias lg='lazygit'
alias lzd='lazydocker'
alias v='nvim'
alias cat='bat --theme=base16'
